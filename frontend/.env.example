VITE_API_BASE_URL=/api/v1

# Realtime (WebSocket) — requires ASGI server + Redis (see README)
# VITE_ENABLE_REALTIME=false
# Direct WS to Django when Vite /ws proxy is unavailable:
# VITE_WS_BASE_URL=ws://localhost:8000

# Branding (optional — defaults to TTU / VoteBridge)
VITE_SYSTEM_NAME=VoteBridge
VITE_SYSTEM_TAGLINE=Secure Campus Election Platform
VITE_INSTITUTION_NAME=Takoradi Technical University
# VITE_INSTITUTION_LOGO_URL=/assets/ttu-logo.png
VITE_ELECTION_OFFICE_EMAIL=elections@ttu.edu.gh
VITE_ELECTION_OFFICE_PHONE=+233 31 229 3000
