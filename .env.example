# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
POSTGRES_DB=votebridge
POSTGRES_USER=votebridge
POSTGRES_PASSWORD=votebridge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Channels
CHANNELS_REDIS_URL=redis://localhost:6379/1

# Frontend (Vite)
VITE_DEV_MODE=True
VITE_DEV_SERVER_HOST=localhost
VITE_DEV_SERVER_PORT=5173

# Branding (optional overrides)
# VITE_AUTH_PANEL_IMAGE_URL=/static/auth/login-campus.webp

# Logging
LOG_LEVEL=INFO

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTH_SESSION_LIFETIME_DAYS=7

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_REQUESTS_PER_WINDOW=5
OTP_REQUEST_WINDOW_MINUTES=15

# Secure Voting Token (SVT)
SVT_EXPIRY_MINUTES=30

# Security alert thresholds
ALERT_LOGIN_ATTEMPTS_WINDOW_MINUTES=15
ALERT_LOGIN_ATTEMPTS_THRESHOLD=5
ALERT_SVT_REQUESTS_WINDOW_MINUTES=60
ALERT_SVT_REQUESTS_THRESHOLD=5
ALERT_VOTING_PATTERN_WINDOW_MINUTES=5
ALERT_VOTING_PATTERN_THRESHOLD=3
ALERT_DEVICE_WINDOW_MINUTES=1440
ALERT_LOCATION_WINDOW_MINUTES=60

# Email
DEFAULT_FROM_EMAIL=noreply@votebridge.local

# Arkesel SMS
# ARKESEL_API_KEY=
# ARKESEL_SENDER_ID=
# ARKESEL_SMS_URL=https://sms.arkesel.com/api/v2/sms/send

# Arkesel USSD
# ARKESEL_USSD_USER_ID=VOTEBRIDGE
# ARKESEL_USSD_CALLBACK_SECRET=
# USSD_SESSION_TIMEOUT_MINUTES=5
# USSD_RATE_LIMIT_PER_MSISDN=30
# Callback URL: https://your-domain/api/v1/ussd/callback/
